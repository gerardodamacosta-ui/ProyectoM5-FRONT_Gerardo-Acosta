rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // perfil de usuario en users/{userId} — cada uno accede solo al suyo
    // create separado de update para que role sea INMUTABLE desde el cliente:
    // - create: solo el propio uid y siempre con role 'customer' (default de todo registro)
    // - update: solo el propio uid y sin poder cambiar role (impide auto-escalada a admin)
    // el ascenso a admin se hace a mano en la consola de Firebase, que saltea estas reglas
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == 'customer';
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;
    }

    // catálogo de productos: lectura pública (Hito 3, catálogo navegable sin login)
    // sin allow write: la escritura queda denegada por default hasta el CRUD admin,
    // que va a chequear el role de users/{uid} (confiable gracias a la inmutabilidad de arriba)
    match /products/{productId} {
      allow read: if true;
    }

    // carts y orders: sin reglas todavía = acceso denegado por defecto
    // se agregan cuando llegue cada módulo
  }
}
