rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // true si el usuario autenticado tiene role 'admin' en su doc de users/{uid} — evita
    // repetir el mismo get() en products/orders (mismo patrón que ya usa el fix de Hito 2)
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // perfil de usuario en users/{userId} — cada uno accede solo al suyo
    // create separado de update para que role sea INMUTABLE desde el cliente:
    // - create: solo el propio uid y siempre con role 'customer' (default de todo registro)
    // - update: solo el propio uid y sin poder cambiar role (impide auto-escalada a admin)
    // el ascenso a admin se hace a mano en la consola de Firebase, que saltea estas reglas
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == 'customer';
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;
    }

    // catálogo de productos: lectura pública (Hito 3, catálogo navegable sin login)
    match /products/{productId} {
      allow read: if true;
      // alta/edición/borrado del catálogo: solo admin, verificado server-side — nunca
      // confiar en que el frontend oculte el botón (mismo criterio que el resto del proyecto)
      allow create, update, delete: if isAdmin();
    }

    // carrito de compras: cada usuario lee/escribe solo el suyo (doc en carts/{userId})
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // órdenes: el cliente solo crea y lee las propias — create fuerza status 'pending'
    // (nunca se manda otro valor desde acá) y userId propio
    match /orders/{orderId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      // lectura: el dueño de la orden, o un admin (el panel de gestión lee todas)
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid || isAdmin());
      // cambio de estado: solo admin — el customer no debe poder tocar el status de su propia orden
      allow update: if isAdmin();
    }
  }
}
